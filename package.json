{
	"name": "pgdozor-frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && npm run lint",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"proto:update": "npm install @buf/pgdozor_backend.bufbuild_es@latest @bufbuild/protobuf@latest"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-node": "^5.5.7",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/d3-scale": "^4.0.9",
		"@types/d3-shape": "^3.1.8",
		"@types/node": "^25.9.3",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"prettier": "^3.9.0",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.0",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"@buf/pgdozor_backend.bufbuild_es": "^2.12.1-20260705151058-3a43b1f6f8f5.1",
		"@bufbuild/protobuf": "^2.12.1",
		"@connectrpc/connect": "^2.1.1",
		"@connectrpc/connect-web": "^2.1.1",
		"@lucide/svelte": "^1.23.0",
		"d3-scale": "^4.0.2",
		"d3-shape": "^3.2.0",
		"layerchart": "2.0.0-next.65",
		"sql-formatter": "^15.8.2"
	}
}
